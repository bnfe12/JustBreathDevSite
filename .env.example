# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
APP_URL=https://justbreath.life
UPLOADED_SITES_ORIGIN=https://sites.justbreath.life
SITE_NAME=justbreath.life
BRAND_WORDMARK=justbreath
DATA_DIR=
BACKUPS_DIR=
DEMO_SEED_MODE=off
ADSENSE_CLIENT_ID=ca-pub-3277248864324139
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# ── Optional demo seed accounts (used only when DEMO_SEED_MODE=on) ────────────
OWNER_HANDLE=Tcheler
OWNER_DISPLAY_NAME=Tcheler
OWNER_EMAIL=andrexarlay@gmail.com
OWNER_PASSWORD=change_this_strong_password_min_8_chars

# ── Brand bot account ─────────────────────────────────────────────────────────
BRAND_HANDLE=justbreath
BRAND_DISPLAY_NAME=justbreath
BRAND_EMAIL=hello@justbreath.life
BRAND_PASSWORD=change_this_strong_password_min_8_chars

# ── Giphy (optional — for GIF picker in chat) ─────────────────────────────────
# Get free key at https://developers.giphy.com/
GIPHY_API_KEY=

# ── Discord OAuth (optional — for Discord sign-in) ────────────────────────────
# Get credentials at https://discord.com/developers/applications
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=https://yourdomain.com/api/auth/discord/callback

# ── Discord support server (optional — shown in Support settings panel) ───────
DISCORD_SUPPORT_URL=

# ── Telegram bridge (optional — preview / scaffolding) ────────────────────────
# Create a bot at https://t.me/BotFather to obtain TELEGRAM_BOT_TOKEN.
# Set TELEGRAM_BOT_USERNAME to the bot's @handle (without @) so the UI can link out.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# ── SMTP (optional — for email verification & password reset) ─────────────────
# If not set, codes will be printed to server console instead.
# Recommended providers: Postmark, Resend, AWS SES, Mailgun, Brevo, Fastmail
# Postmark:  SMTP_HOST=smtp.postmarkapp.com  SMTP_PORT=587
# Resend:    SMTP_HOST=smtp.resend.com       SMTP_PORT=465
# SES eu-w1: SMTP_HOST=email-smtp.eu-west-1.amazonaws.com  SMTP_PORT=587
# Mailgun:   SMTP_HOST=smtp.mailgun.org      SMTP_PORT=587
# ALLOW_DEV_EMAIL_LOG=1 is for isolated localhost development only. Do not enable it on shared staging or production.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@justbreath.life
ALLOW_DEV_EMAIL_LOG=0
